<launch>
 <arg name="headless" default="false"/>
 <!-- 发布机器人状态 -->
<node name="joint_state_publisher" pkg="joint_state_publisher" type="joint_state_publisher" />
<node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" />
 <!-- 启动 Gazebo，加载迷宫世界 -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(find maze_mapping)/worlds/maze.world"/>
  </include>
  <!-- 加载机器人 -->
  <include file="$(find my_robot)/launch/robot.launch">
  </include>

  <!-- 运行 gmapping -->
  <node pkg="gmapping" type="slam_gmapping" name="slam_gmapping" output="screen">
    <remap from="scan" to="/scan"/>
    <param name="base_frame" value="base_link"/>
    <param name="odom_frame" value="odom"/>
    <param name="map_frame" value="map"/>
  </node>

  <!-- 键盘遥控 -->
  <node pkg="teleop_twist_keyboard" type="teleop_twist_keyboard.py" name="teleop_key"/>
  
  <!-- RViz -->
  <node pkg="rviz" type="rviz" name="rviz" args="-d $(find maze_mapping)/rviz/gapping.rviz" unless="$(arg headless)"/>
</launch>